@model MVC_DenoyJabines.Models.Users

@{
    ViewData["Title"] = "Delete User";
}

<div class="container mt-4">
    <h2>🗑 Delete User</h2>
    <div class="alert alert-danger">
        Are you sure you want to deactivate <strong>@Model.Username</strong>?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@Model.Username</dd>
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
        <dt class="col-sm-2">Role</dt>
        <dd class="col-sm-10">@Model.Role</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <a asp-action="UsersIndex" class="btn btn-secondary">⬅ Cancel</a>
        <button type="submit" class="btn btn-danger">🗑 Yes, Deactivate</button>
    </form>
</div>