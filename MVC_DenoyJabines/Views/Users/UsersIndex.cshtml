@model IEnumerable<MVC_DenoyJabines.Models.Users>

@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <h2>📋 User Management</h2>
    <div class="mb-3">
        <a asp-action="UsersIndex" asp-route-status="all" class="btn btn-outline-secondary btn-sm">All</a>
        <a asp-action="UsersIndex" asp-route-status="active" class="btn btn-outline-success btn-sm">Active</a>
        <a asp-action="UsersIndex" asp-route-status="inactive" class="btn btn-outline-danger btn-sm">Inactive</a>
    </div>

    <table class="table table-striped table-bordered table-hover align-middle text-center shadow-sm mt-3">
        <thead class="table-dark">
            <tr>
                <th class="text-start">Username</th>
                <th class="text-start">Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-muted">No users found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-start">@item.Username</td>
                        <td class="text-start">@item.Email</td>
                        <td>@item.Role</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-primary">✏️ Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-sm btn-danger">🗑 Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>