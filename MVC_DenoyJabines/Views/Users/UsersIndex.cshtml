@model IEnumerable<MVC_DenoyJabines.Models.Users>

@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
}
<h2>User Management</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th style="width:200px;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Username</td>
                <td>@item.Email</td>
                <td>@item.Role</td>

                <td>

                    <button class="btn btn-info btn-sm"
                            onclick="viewUser('@item.Username','@item.Email','@item.Role')">
                        View
                    </button>

                    <button class="btn btn-warning btn-sm"
                            onclick="editUser('@item.UserId','@item.Username','@item.Email','@item.Role')">
                        Edit
                    </button>

                    <a asp-action="DeleteUser"
                       asp-route-id="@item.UserId"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

<!-- ================= VIEW PANEL ================= -->

<div id="viewPanel" class="card p-3 mt-3" style="display:none;">

    <h4>User Details</h4>

    <p><strong>Username:</strong> <span id="viewUsername"></span></p>
    <p><strong>Email:</strong> <span id="viewEmail"></span></p>
    <p><strong>Role:</strong> <span id="viewRole"></span></p>

    <button class="btn btn-secondary" onclick="closePanels()">Close</button>

</div>


<!-- ================= EDIT PANEL ================= -->

<div id="editPanel" class="card p-3 mt-3" style="display:none;">

    <h4>Edit User</h4>

    <form asp-action="UpdateUser" method="post">

        <input type="hidden" id="editId" name="UserId" />

        <div class="mb-3">
            <label class="form-label">Username</label>
            <input id="editUsername" name="Username" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input id="editEmail" name="Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Role</label>
            <select id="editRole" name="Role" class="form-control">
                <option value="Admin">Admin</option>
                <option value="Counselor">Counselor</option>
            </select>
        </div>

        <button type="submit" class="btn btn-success">Save</button>

        <button type="button" class="btn btn-secondary" onclick="closePanels()">Cancel</button>

    </form>

</div>


<script>

    function viewUser(username,email,role)
    {
        document.getElementById("viewPanel").style.display = "block";
        document.getElementById("editPanel").style.display = "none";

        document.getElementById("viewUsername").innerText = username;
        document.getElementById("viewEmail").innerText = email;
        document.getElementById("viewRole").innerText = role;
    }

    function editUser(id,username,email,role)
    {
        document.getElementById("editPanel").style.display = "block";
        document.getElementById("viewPanel").style.display = "none";

        document.getElementById("editId").value = id;
        document.getElementById("editUsername").value = username;
        document.getElementById("editEmail").value = email;
        document.getElementById("editRole").value = role;
    }

    function closePanels()
    {
        document.getElementById("viewPanel").style.display = "none";
        document.getElementById("editPanel").style.display = "none";
    }

</script>