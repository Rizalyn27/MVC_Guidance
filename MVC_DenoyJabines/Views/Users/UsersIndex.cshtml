@model IEnumerable<MVC_DenoyJabines.Models.Users>

@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h2>📋 User Management</h2>

    <table class="table table-striped table-bordered table-hover align-middle text-center shadow-sm mt-3">
        <thead class="table-dark">
            <tr>
                <th class="text-start">Username</th>
                <th class="text-start">Email</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="3" class="text-muted">No users found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-start">@item.Username</td>
                        <td class="text-start">@item.Email</td>
                        <td>@item.Role</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>