    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

@{

    <main class="hero-section">
        <div class="container hero-container">

            <div class="hero-left">
                <h1 class="hero-title">Guidance and Counseling</h1>
                <div class="hero-image-wrapper">
                    <img src="/photos/counsel.png" alt="Illustration of a counseling session" class="hero-image">
                </div>
            </div>

            <div class="hero-right">
                <div class="login-card">

                    @if (ViewBag.Error != null)
                    {
                        <div class="error-box show">
                            @ViewBag.Error
                        </div>
                    }

                    <form class="login-form" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <input name="username"
                                   class="form-control"
                                   placeholder="Username" />
                            <small class="helper-text">
                                Enter your registered Username or Email
                            </small>
                        </div>

                        <div class="form-group">
                            <input type="password"
                                   name="password"
                                   class="form-control"
                                   placeholder="Password" />
                            <small class="helper-text">
                                Enter your secure password
                            </small>
                        </div>

                        <button type="submit" class="btn-login">
                            Login
                        </button>

                        <a href="@Url.Action("Register", "Login")" class="helper-text" style="margin-left:80px;">
                            Don't have an account? Register here
                        </a>

                    </form>

                </div>
            </div>
        </div>
    </main>

    <!-- Footer / Profile Section -->
    <footer class="profile-section">
        <div class="profile-container">
            <div class="profile-card">
                <div class="avatar-wrapper">
                    <img src="/photos/avatar.png" alt="Rizalyn Denoy" class="avatar">
                </div>
                <div class="profile-info">
                    <h2 class="profile-name">Rizalyn Denoy</h2>
                    <div class="profile-tags">
                        <span class="tag">Counsellor</span>
                        <span class="tag">Advisor</span>
                    </div>
                    <p class="profile-tagline">Here to guide you every step of the way.</p>
                </div>
            </div>
        </div>
    </footer>
}