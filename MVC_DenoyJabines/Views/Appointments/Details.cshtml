@model MVC_DenoyJabines.Models.Appointment
@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">📋 Appointment Details</h4>
        </div>

        <div class="card-body">

            <!-- 👤 PERSONAL INFO -->
            <h5 class="text-primary">👤 Personal Information</h5>
            <hr />

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">First Name</label>
                    <p class="form-control-plaintext">@Model.FirstName</p>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Last Name</label>
                    <p class="form-control-plaintext">@Model.LastName</p>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Middle Name</label>
                    <p class="form-control-plaintext">@(string.IsNullOrEmpty(Model.MiddleName) ? "—" : Model.MiddleName)</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <p class="form-control-plaintext">@Model.Email</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Contact Number</label>
                    <p class="form-control-plaintext">@Model.ContactNumber</p>
                </div>
            </div>

            <!-- 📅 APPOINTMENT DETAILS -->
            <h5 class="text-warning mt-4">📅 Appointment Details</h5>
            <hr />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Appointment Date</label>
                    <p class="form-control-plaintext">@Model.AppointmentDate.ToString("MMMM dd, yyyy hh:mm tt")</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Appointment Type</label>
                    <p class="form-control-plaintext">@Model.AppointmentType</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Status</label>
                    <p class="form-control-plaintext">
                        @switch (Model.Status)
                        {
                            case "Pending":
                                <span class="badge bg-warning text-dark">⏳ Pending</span>
                                break;
                            case "Confirmed":
                                <span class="badge bg-success">✅ Confirmed</span>
                                break;
                            case "Cancelled":
                                <span class="badge bg-danger">❌ Cancelled</span>
                                break;
                            case "Completed":
                                <span class="badge bg-primary">🎓 Completed</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@Model.Status</span>
                                break;
                        }
                    </p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Submitted By</label>
                    <p class="form-control-plaintext">@(Model.User?.Username ?? "—")</p>
                </div>
                <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Notes</label>
                    <p class="form-control-plaintext">@(string.IsNullOrEmpty(Model.Notes) ? "—" : Model.Notes)</p>
                </div>
            </div>

            <!-- 🕓 AUDIT INFO -->
            <h5 class="text-secondary mt-4">🕓 Record Info</h5>
            <hr />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Created At</label>
                    <p class="form-control-plaintext">@Model.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Last Updated</label>
                    <p class="form-control-plaintext">
                        @(Model.UpdatedAt.HasValue? Model.UpdatedAt.Value.ToString("MMMM dd, yyyy hh:mm tt") : "—")
                    </p>
                </div>
            </div>

            <!-- BUTTONS -->
            <div class="d-flex justify-content-between mt-3">
                @if (User.IsInRole("Student"))
                {
                    <a asp-action="StudentsAppt" class="btn btn-secondary">⬅ Back</a>
                }
                else
                {
                    <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
                }
                <a asp-action="Edit" asp-route-id="@Model.AppointmentID" class="btn btn-primary">✏️ Edit</a>
            </div>

        </div>
    </div>
</div>