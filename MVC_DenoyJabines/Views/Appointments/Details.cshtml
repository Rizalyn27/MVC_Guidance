@model MVC_DenoyJabines.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">

        <!-- HEADER -->
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">📋 Appointment Details</h4>
        </div>

        <div class="card-body">

            <!-- 👤 CLIENT INFO -->
            <h5 class="text-primary mt-3">👤 Client Information</h5>
            <hr />
            <div class="row">
                <div class="col-md-4 mb-2"><strong>First Name:</strong> @Html.DisplayFor(model => model.FirstName)</div>
                <div class="col-md-4 mb-2"><strong>Last Name:</strong> @Html.DisplayFor(model => model.LastName)</div>
                <div class="col-md-4 mb-2"><strong>Middle Name:</strong> @Html.DisplayFor(model => model.MiddleName)</div>
            </div>

            <!-- 📬 CONTACT -->
            <h5 class="text-success mt-3">📬 Contact Details</h5>
            <hr />
        <div class="row">
                <div class="col-md-6 mb-2"><strong>Email:</strong> @Html.DisplayFor(model => model.Email)</div>
                <div class="col-md-6 mb-2"><strong>Contact Number:</strong> @Html.DisplayFor(model => model.ContactNumber)</div>
        </div>

            <!-- 📅 APPOINTMENT DETAILS -->
            <h5 class="text-warning mt-3">📅 Appointment Info</h5>
            <hr />
        <div class="row">
                <div class="col-md-4 mb-2"><strong>Date:</strong> @Html.DisplayFor(model => model.AppointmentDate)</div>
                <div class="col-md-4 mb-2"><strong>Type:</strong> @Html.DisplayFor(model => model.AppointmentType)</div>
                <div class="col-md-4 mb-2"><strong>Status:</strong> @Html.DisplayFor(model => model.Status)</div>
        </div>

            <!-- 📝 NOTES -->
            <h5 class="text-info mt-3">📝 Notes</h5>
            <hr />
            <div class="mb-3">
                @Html.DisplayFor(model => model.Notes)
        </div>

            <!-- ⚙️ SYSTEM INFO -->
            <h5 class="text-secondary mt-3">⚙️ System Info</h5>
            <hr />
            <div class="row">
                <div class="col-md-6 mb-2"><strong>Created At:</strong> @Html.DisplayFor(model => model.CreatedAt)</div>
                <div class="col-md-6 mb-2"><strong>Updated At:</strong> @Html.DisplayFor(model => model.UpdatedAt)</div>
        </div>

            <!-- ACTION BUTTONS -->
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Edit" asp-route-id="@Model?.AppointmentID" class="btn btn-primary">✏️ Edit</a>
                @{
                    var roleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                    var backAction = roleClaim == "Student" ? "StudentAppointments" : "Index";
                }
                <a asp-action="@backAction" class="btn btn-secondary">⬅ Back</a>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.AppointmentID" class="btn btn-primary">✏️ Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.AppointmentID" class="btn btn-danger">🗑 Cancel</a>
        </div>
    </div>
</div>