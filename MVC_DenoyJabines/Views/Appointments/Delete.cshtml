@model MVC_DenoyJabines.Models.Appointment
@{
    ViewData["Title"] = "Delete Appointment";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:wght@400;500&display=swap');

    :root {
        --rose: #e11d48;
        --rose-light: #fff1f2;
        --rose-border: #fecdd3;
        --teal: #0d9488;
        --teal-light: #ccfbf1;
        --amber: #f59e0b;
        --amber-light: #fef3c7;
        --surface: #f8fafc;
        --card: #ffffff;
        --border: #e2e8f0;
        --text: #0f172a;
        --muted: #64748b;
        --radius: 16px;
    }

    body { background: var(--surface); font-family: 'DM Sans', sans-serif; color: var(--text); }
    .appt-page { padding: 32px 16px; max-width: 860px; margin: 0 auto; }

    .page-eyebrow {
        display: flex; align-items: center; gap: 10px;
        font-family: 'Outfit', sans-serif; font-size: 0.75rem; font-weight: 700;
        letter-spacing: 1.2px; text-transform: uppercase; color: var(--rose); margin-bottom: 6px;
    }
    .page-eyebrow::before { content: ''; display: inline-block; width: 20px; height: 2px; background: var(--rose); }

    .page-title {
        font-family: 'Outfit', sans-serif; font-size: clamp(1.5rem, 4vw, 2rem);
        font-weight: 800; color: var(--text); margin: 0 0 20px;
    }

    .danger-banner {
        background: var(--rose-light); border: 1.5px solid var(--rose-border);
        border-radius: 12px; padding: 14px 20px;
        display: flex; align-items: flex-start; gap: 12px; margin-bottom: 24px;
    }
    .danger-banner .d-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 1px; }
    .danger-banner strong { font-family: 'Outfit', sans-serif; font-size: 0.92rem; font-weight: 700; color: #9f1239; display: block; margin-bottom: 2px; }
    .danger-banner p { font-size: 0.82rem; color: #be123c; margin: 0; }

    .detail-card {
        background: var(--card); border-radius: var(--radius);
        border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(0,0,0,0.06); overflow: hidden; margin-bottom: 20px;
    }

    .section-header { padding: 20px 28px 0; display: flex; align-items: center; gap: 10px; }
    .section-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
    .section-icon.teal { background: var(--teal-light); }
    .section-icon.amber { background: var(--amber-light); }
    .section-label { font-family: 'Outfit', sans-serif; font-size: 0.95rem; font-weight: 700; color: var(--text); }
    .section-divider { height: 1px; background: var(--border); margin: 14px 28px 0; }
    .detail-body { padding: 20px 28px 24px; }

    .detail-grid { display: grid; gap: 18px; }
    .detail-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .detail-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
    .detail-grid.cols-1 { grid-template-columns: 1fr; }

    .detail-field label { display: block; font-size: 0.75rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 5px; }
    .detail-value { font-size: 0.92rem; color: var(--text); padding: 9px 14px; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border); min-height: 38px; }

    .form-actions {
        display: flex; justify-content: space-between; align-items: center;
        padding: 20px 28px; border-top: 1px solid var(--border);
        background: #fafafa; gap: 12px; flex-wrap: wrap;
    }

    .btn {
        display: inline-flex; align-items: center; gap: 7px; padding: 10px 22px; border-radius: 10px;
        font-family: 'Outfit', sans-serif; font-size: 0.88rem; font-weight: 600;
        text-decoration: none; border: none; cursor: pointer; transition: all .18s; white-space: nowrap;
    }
    .btn-back { background: #f1f5f9; color: var(--muted); border: 1.5px solid var(--border); }
    .btn-back:hover { background: #e2e8f0; color: var(--text); }
    .btn-delete { background: var(--rose); color: #fff; box-shadow: 0 2px 8px rgba(225,29,72,.22); }
    .btn-delete:hover { background: #be123c; }

    @@media (max-width: 768px) {
        .detail-grid.cols-3, .detail-grid.cols-2 { grid-template-columns: 1fr; }
        .appt-page { padding: 20px 12px; }
        .detail-body { padding: 16px 18px 20px; }
        .section-header { padding: 16px 18px 0; }
        .section-divider { margin: 12px 18px 0; }
        .form-actions { padding: 16px 18px; }
    }
</style>

<div class="appt-page">
    <div class="page-eyebrow">Appointments</div>
    <h1 class="page-title">🗑️ Delete Appointment</h1>

    <div class="danger-banner">
        <div class="d-icon">⚠️</div>
        <div>
            <strong>Are you sure you want to delete this appointment?</strong>
            <p>This action cannot be undone. Please review the details below before confirming.</p>
        </div>
    </div>

    <div class="detail-card">
        <div class="section-header">
            <div class="section-icon teal">👤</div>
            <span class="section-label">Personal Information</span>
        </div>
        <div class="section-divider"></div>
        <div class="detail-body">
            <div class="detail-grid cols-3">
                <div class="detail-field"><label>First Name</label><div class="detail-value">@Model.FirstName</div></div>
                <div class="detail-field"><label>Last Name</label><div class="detail-value">@Model.LastName</div></div>
                <div class="detail-field"><label>Middle Name</label><div class="detail-value">@(string.IsNullOrEmpty(Model.MiddleName) ? "—" : Model.MiddleName)</div></div>
            </div>
            <div class="detail-grid cols-2" style="margin-top:18px;">
                <div class="detail-field"><label>Email</label><div class="detail-value">@Model.Email</div></div>
                <div class="detail-field"><label>Contact Number</label><div class="detail-value">@Model.ContactNumber</div></div>
            </div>
        </div>

        <div class="section-header">
            <div class="section-icon amber">📅</div>
            <span class="section-label">Appointment Details</span>
        </div>
        <div class="section-divider"></div>
        <div class="detail-body">
            <div class="detail-grid cols-2">
                <div class="detail-field"><label>Appointment Date</label><div class="detail-value">@Model.AppointmentDate.ToString("MMMM dd, yyyy hh:mm tt")</div></div>
                <div class="detail-field"><label>Appointment Type</label><div class="detail-value">@Model.AppointmentType</div></div>
                <div class="detail-field"><label>Status</label><div class="detail-value">@Model.Status</div></div>
                <div class="detail-field"><label>Submitted By</label><div class="detail-value">@(Model.User?.Username ?? "—")</div></div>
            </div>
            <div class="detail-grid cols-1" style="margin-top:18px;">
                <div class="detail-field"><label>Notes</label><div class="detail-value">@(string.IsNullOrEmpty(Model.Notes) ? "—" : Model.Notes)</div></div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="AppointmentID" />
            <div class="form-actions">
                @if (User.IsInRole("Student"))
                {
                    <a asp-action="StudentsAppt" class="btn btn-back">⬅ Back</a>
                }
                else
                {
                    <a asp-action="Index" class="btn btn-back">⬅ Back</a>
                }
                <button type="submit" class="btn btn-delete">🗑️ Confirm Delete</button>
            </div>
        </form>
    </div>
</div>
