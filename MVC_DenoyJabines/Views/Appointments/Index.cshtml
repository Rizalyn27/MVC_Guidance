@model IEnumerable<MVC_DenoyJabines.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
    bool isPrivileged = (bool)(ViewBag.IsCounselorOrAdmin ?? false);
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@600&display=swap');

    .appt-page {
        font-family: 'DM Sans', sans-serif;
    }

        .appt-page h2 {
            font-family: 'Playfair Display', serif;
            color: #1a1a2e;
        }

    .filter-pill {
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        padding: 5px 16px;
        border: 1.5px solid #dee2e6;
        color: #555;
        text-decoration: none;
        transition: all .2s;
    }

        .filter-pill:hover, .filter-pill.active {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }

    .appt-table th {
        background: #1a1a2e;
        color: #fff;
        font-weight: 500;
        font-size: 0.85rem;
        letter-spacing: .04em;
    }

    .appt-table td {
        vertical-align: middle;
        font-size: 0.9rem;
    }

    .appt-table tbody tr {
        transition: background .15s;
    }

        .appt-table tbody tr:hover {
            background: #f0f4ff;
        }

    .badge-pending {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffc107;
        border-radius: 12px;
        padding: 3px 10px;
        font-size: .78rem;
    }

    .badge-completed {
        background: #d1e7dd;
        color: #0a3622;
        border: 1px solid #198754;
        border-radius: 12px;
        padding: 3px 10px;
        font-size: .78rem;
    }

    .badge-cancelled {
        background: #f8d7da;
        color: #58151c;
        border: 1px solid #dc3545;
        border-radius: 12px;
        padding: 3px 10px;
        font-size: .78rem;
    }
</style>

<div class="container mt-4 appt-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🗓 Appointments</h2>
        <a asp-action="Create" class="btn btn-sm btn-dark px-4">+ New Appointment</a>
    </div>

    <div class="d-flex gap-2 mb-3">
        <a asp-action="Index" asp-route-status="all"
           class="filter-pill @(string.IsNullOrEmpty(ViewBag.CurrentStatus as string) || ViewBag.CurrentStatus == "all" ? "active" : "")">All</a>
        <a asp-action="Index" asp-route-status="Pending"
           class="filter-pill @(ViewBag.CurrentStatus == "Pending" ? "active" : "")">Pending</a>
        <a asp-action="Index" asp-route-status="Completed"
           class="filter-pill @(ViewBag.CurrentStatus == "Completed" ? "active" : "")">Completed</a>
        <a asp-action="Index" asp-route-status="Cancelled"
           class="filter-pill @(ViewBag.CurrentStatus == "Cancelled" ? "active" : "")">Cancelled</a>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-bordered table-hover mb-0 appt-table">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Date & Time</th>
                    <th>Type</th>
                    <th>Status</th>
                    @if (isPrivileged)
                    {
                        <th>Counselor</th>
                    }
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@(isPrivileged ? 6 : 5)" class="text-center text-muted py-4">
                            No appointments found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td>@a.Student?.StuFName @a.Student?.StuLName</td>
                            <td>@a.AppointmentDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                            <td>@a.AppointmentType</td>
                            <td>
                                <span class="badge-@a.Status.ToLower()">@a.Status</span>
                            </td>
                            @if (isPrivileged)
                            {
                                <td>@(a.Counselor?.Username ?? "—")</td>
                            }
                            <td class="text-center">
                                @if (isPrivileged)
                                {
                                    <a asp-action="Details" asp-route-id="@a.AppointmentID" class="btn btn-sm btn-outline-dark">👁 View</a>
                                    <a asp-action="Edit" asp-route-id="@a.AppointmentID" class="btn btn-sm btn-primary">✏️ Edit</a>
                                    <a asp-action="Delete" asp-route-id="@a.AppointmentID" class="btn btn-sm btn-danger">🗑</a>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic" style="font-size:.8rem;">View only</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>