@model MVC_DenoyJabines.Models.Appointment

@{
    ViewData["Title"] = "Create Appointment";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">📅 Create Appointment</h4>
        </div>

        <div class="card-body">

            <!-- Validation Summary -->
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger">
                    <strong>Please fix the following errors:</strong>
                </div>

                <!-- 👤 CLIENT INFO -->
                <h5 class="text-primary">👤 Client Information</h5>
                <hr />
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" class="form-control @(ViewData.ModelState["FirstName"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="FirstName" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" class="form-control @(ViewData.ModelState["LastName"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="LastName" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="MiddleName"></label>
                        <input asp-for="MiddleName" class="form-control @(ViewData.ModelState["MiddleName"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="MiddleName" class="invalid-feedback"></span>
                    </div>
                </div>

                <!-- 📬 CONTACT -->
                <h5 class="text-success mt-4">📬 Contact Details</h5>
                <hr />
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" class="form-control @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ContactNumber"></label>
                        <input asp-for="ContactNumber" class="form-control @(ViewData.ModelState["ContactNumber"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="ContactNumber" class="invalid-feedback"></span>
                    </div>
                </div>

                <!-- 📅 APPOINTMENT DETAILS -->
                <h5 class="text-warning mt-4">📅 Appointment Details</h5>
                <hr />
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="AppointmentDate"></label>
                        <input asp-for="AppointmentDate" type="datetime-local" class="form-control @(ViewData.ModelState["AppointmentDate"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="AppointmentDate" class="invalid-feedback"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="AppointmentType"></label>
                        <input asp-for="AppointmentType" class="form-control @(ViewData.ModelState["AppointmentType"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="AppointmentType" class="invalid-feedback"></span>
                    </div>

                </div>

                <!-- 📝 NOTES -->
                <h5 class="text-info mt-4">📝 Notes</h5>
                <hr />
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="Notes"></label>
                        <textarea asp-for="Notes" class="form-control @(ViewData.ModelState["Notes"]?.Errors.Count > 0 ? "is-invalid" : "")"></textarea>
                        <span asp-validation-for="Notes" class="invalid-feedback"></span>
                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-between">
                    @{
                        var roleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                        var backAction = roleClaim == "Student" ? "StudentAppointments" : "Index";
                    }
                    <a asp-action="@backAction" class="btn btn-secondary">⬅ Back</a>
                    <button type="submit" class="btn btn-success">💾 Save Appointment</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}