@{
    if (User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
    else if (User.IsInRole("Counselor"))
    {
        Layout = "_Layout"; //  counselor layout
    }
    else if (User.IsInRole("Student"))
    {
        Layout = "_StudentLayout";
    }
    else
    {
        Layout = "_StudentLayout";
    }
}
