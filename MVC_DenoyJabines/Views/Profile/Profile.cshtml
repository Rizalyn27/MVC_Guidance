@model IEnumerable<MVC_DenoyJabines.Models.Students>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.StuFullName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.GradeSec)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.StuLRN)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.StuStatus)
                </th>
                <th>
                    Action
                </th>
                <th>
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.StuFullName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.GradeSec)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StuLRN)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StuStatus)
                    </td>
                    <td>
                     <!--View-->
                        <button class="btn btn-primary" 
                        onclick="openEditPanel(this)"
                        data-id="@item.StuID"
                        data-stulrn="@item.StuLRN"
                        
                        >View</button>
                     <!--Delete-->
                        <button type="submit">
                            <img src="~/images/pencil.png" width="25" height="25" /> 
                        </button>

                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div id="editPanel" class="card mt-3" style="display:none;">
        <div class="card-header d-flex justify-content-between">
            <h5>Student Details / Edit</h5>
            <button type="button" class="btn btn-sm btn-secondary" onclick="closeEditPanel()">X</button>
        </div>

        <div class="card-body">
            <form id="editForm">
                <input type="hidden" id="StudentID" name="StudentID" />

                <h6>Basic Info</h6>
                <div class="mb-2">
                    <label>Student ID</label>
                    <input type="text" class="form-control" id="StuID" name="StuID" />
                </div>
                <div class="mb-2">
                    <label>First Name</label>
                    <input type="text" class="form-control" id="StuFName" name="StuFName" />
                </div>
                <div class="mb-2">
                    <label>Middle Name</label>
                    <input type="text" class="form-control" id="StuMName" name="StuMName" />
                </div>
                <div class="mb-2">
                    <label>Last Name</label>
                    <input type="text" class="form-control" id="StuLName" name="StuLName" />
                </div>
                <div class="mb-2">
                    <label>Gender</label>
                    <select class="form-control" id="Gender" name="Gender">
                        <option>Male</option>
                        <option>Female</option>
                    </select>
                </div>
                <div class="mb-2">
                    <label>Birthdate</label>
                    <input type="date" class="form-control" id="Birthdate" name="Birthdate" />
                </div>
                <div class="mb-2">
                    <label>Address</label>
                    <input type="text" class="form-control" id="Address" name="Address" />
                </div>
                <div class="mb-2">
                    <label>Contact</label>
                    <input type="text" class="form-control" id="Contact" name="Contact" />
                </div>
                <div class="mb-2">
                    <label>Email</label>
                    <input type="email" class="form-control" id="Email" name="Email" />
                </div>

                <h6>Academic Info</h6>
                <div class="mb-2">
                    <label>Department</label>
                    <input type="text" class="form-control" id="Department" name="Department" />
                </div>
                <div class="mb-2">
                    <label>Year Level</label>
                    <input type="text" class="form-control" id="YearLevel" name="YearLevel" />
                </div>
                <div class="mb-2">
                    <label>Section</label>
                    <input type="text" class="form-control" id="Section" name="Section" />
                </div>
                <div class="mb-2">
                    <label>Adviser</label>
                    <input type="text" class="form-control" id="Adviser" name="Adviser" />
                </div>

                <h6>Guardian Info</h6>
                <div class="mb-2">
                    <label>Guardian Name</label>
                    <input type="text" class="form-control" id="GuardianName" name="GuardianName" />
                </div>
                <div class="mb-2">
                    <label>Relationship</label>
                    <input type="text" class="form-control" id="Relationship" name="Relationship" />
                </div>
                <div class="mb-2">
                    <label>Guardian Contact</label>
                    <input type="text" class="form-control" id="GuardianContact" name="GuardianContact" />
                </div>
                <div class="mb-2">
                    <label>Guardian Address</label>
                    <input type="text" class="form-control" id="GuardianAddress" name="GuardianAddress" />
                </div>

                <h6>Guidance Info</h6>
                <div class="mb-2">
                    <label>Reason</label>
                    <input type="text" class="form-control" id="Reason" name="Reason" />
                </div>
                <div class="mb-2">
                    <label>Case Type</label>
                    <input type="text" class="form-control" id="CaseType" name="CaseType" />
                </div>
                <div class="mb-2">
                    <label>Counseling Status</label>
                    <select class="form-control" id="CounselingStatus" name="CounselingStatus">
                        <option>Open</option>
                        <option>Closed</option>
                        <option>Pending</option>
                    </select>
                </div>
                <div class="mb-2">
                    <label>Remarks</label>
                    <textarea class="form-control" id="Remarks" name="Remarks"></textarea>
                </div>

                <button type="button" class="btn btn-success" onclick="saveStudent()">Save</button>
                <button type="button" class="btn btn-secondary" onclick="closeEditPanel()">Cancel</button>
            </form>
        </div>
    </div>

}

<script>

        function openEditPanel(studentId) 
        {
            document.getElementById('editPanel').style.display = 'block';
            

</script>
