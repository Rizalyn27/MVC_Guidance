@model MVC_DenoyJabines.Models.Students
@{
    ViewData["Title"] = "Student Details";

    string GetInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "?";
        var parts = fullName.Trim().Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    var initials = GetInitials(Model.StuFullName);
}

<style>
    :root {
        --indigo: #3b5bdb;
        --indigo-soft: #eef1fd;
        --emerald: #0f9d74;
        --emerald-soft: #e6f7f2;
        --amber: #d97706;
        --amber-soft: #fef3e2;
        --cyan: #0891b2;
        --cyan-soft: #e0f5fa;
        --rose: #e5344a;
        --rose-soft: #fdeef0;
        --ink: #0e1523;
        --muted: #6b7696;
        --faint: #a8b0c8;
        --border: #e4e8f4;
        --surface: #ffffff;
        --bg: #f0f2f8;
        --radius: 16px;
        --radius-sm: 10px;
        --shadow: 0 2px 16px rgba(14,21,35,0.07);
        --shadow-md: 0 4px 24px rgba(14,21,35,0.10);
    }

    .sd-wrapper {
        font-family: Arial, Helvetica, sans-serif;
        background: var(--bg);
        min-height: 100vh;
        padding: 28px 32px 48px;
    }

    /* ── Breadcrumb ── */
    .sd-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 22px;
        font-size: 0.82rem;
        color: var(--faint);
    }

        .sd-breadcrumb a {
            color: var(--muted);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .sd-breadcrumb a:hover {
                color: var(--emerald);
                text-decoration: none;
            }

    .sd-breadcrumb-btn {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 5px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--ink);
        cursor: pointer;
        text-decoration: none;
        transition: border-color .15s;
    }

        .sd-breadcrumb-btn:hover {
            border-color: var(--emerald);
            color: var(--emerald);
            text-decoration: none;
        }

    .sd-breadcrumb-sep {
        color: var(--border);
    }

    .sd-breadcrumb-current {
        color: var(--ink);
        font-weight: 700;
    }

    /* ── Hero Card ── */
    .sd-hero {
        background: var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        padding: 24px 28px;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .sd-avatar {
        width: 72px;
        height: 72px;
        border-radius: 14px;
        background: var(--emerald);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        flex-shrink: 0;
        letter-spacing: -0.02em;
    }

    .sd-hero-info {
        flex: 1;
        min-width: 180px;
    }

    .sd-hero-name {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--ink);
        margin: 0 0 3px;
        line-height: 1.25;
    }

    .sd-hero-meta {
        font-size: 0.8rem;
        color: var(--muted);
        margin: 0 0 12px;
    }

    .sd-hero-contacts {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        font-size: 0.8rem;
        color: var(--muted);
    }

    .sd-hero-contact-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .sd-hero-badges {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .sd-badge {
        border-radius: 20px;
        padding: 5px 13px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .sd-badge-active {
        background: var(--emerald-soft);
        color: var(--emerald);
    }

    .sd-badge-inactive {
        background: #f0f0f0;
        color: #888;
    }

    .sd-badge-case {
        background: var(--indigo-soft);
        color: var(--indigo);
    }

    .sd-hero-actions {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }

    .sd-btn {
        border-radius: var(--radius-sm);
        padding: 8px 16px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all .15s;
        font-family: Arial, Helvetica, sans-serif;
    }

    .sd-btn-edit {
        background: var(--surface);
        border: 1.5px solid var(--border);
        color: var(--ink);
    }

        .sd-btn-edit:hover {
            border-color: var(--emerald);
            color: var(--emerald);
            text-decoration: none;
        }

    /* ── Tabs ── */
    .sd-tabs {
        display: flex;
        gap: 0;
        border-bottom: 2px solid var(--border);
        margin-bottom: 22px;
    }

    .sd-tab {
        padding: 11px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--faint);
        cursor: pointer;
        text-decoration: none;
        border-bottom: 2.5px solid transparent;
        margin-bottom: -2px;
        transition: color .15s, border-color .15s;
        display: inline-block;
    }

        .sd-tab:hover {
            color: var(--emerald);
            text-decoration: none;
        }

        .sd-tab.active {
            color: var(--emerald);
            border-bottom-color: var(--emerald);
        }

    /* ── Cards Grid ── */
    .sd-cards-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .sd-info-card {
        background: var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        padding: 22px;
    }

        .sd-info-card.full {
            grid-column: 1 / -1;
        }

    .sd-info-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 6px 10px;
        border-radius: 7px;
        margin-bottom: 18px;
    }

    .sch-indigo {
        background: var(--indigo-soft);
        color: var(--indigo);
    }

    .sch-emerald {
        background: var(--emerald-soft);
        color: var(--emerald);
    }

    .sch-amber {
        background: var(--amber-soft);
        color: var(--amber);
    }

    .sch-cyan {
        background: var(--cyan-soft);
        color: var(--cyan);
    }

    .sch-rose {
        background: var(--rose-soft);
        color: var(--rose);
    }

    .sd-field {
        margin-bottom: 16px;
    }

        .sd-field:last-child {
            margin-bottom: 0;
        }

    .sd-field-label {
        font-size: 0.67rem;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: var(--faint);
        margin: 0 0 4px;
    }

    .sd-field-value {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--ink);
        margin: 0;
    }

        .sd-field-value.muted {
            color: var(--faint);
            font-style: italic;
            font-weight: 400;
        }

    .sd-guidance-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    /* ── Responsive ── */
    @@media (max-width: 1000px) {
        .sd-cards-grid {
            grid-template-columns: 1fr 1fr;
        }

        .sd-guidance-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .sd-wrapper {
            padding: 20px 16px 40px;
        }

        .sd-cards-grid {
            grid-template-columns: 1fr;
        }

        .sd-guidance-grid {
            grid-template-columns: 1fr;
        }

        .sd-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .sd-hero-badges {
            margin-left: 0;
        }
    }
</style>

<div class="sd-wrapper">

    <!-- Breadcrumb -->
    <div class="sd-breadcrumb">
        <a asp-action="Index" class="sd-breadcrumb-btn">← Back</a>
        <span class="sd-breadcrumb-sep">/</span>
        <a asp-action="Index">Student List</a>
        <span class="sd-breadcrumb-sep">/</span>
        <span class="sd-breadcrumb-current">@Model.StuFullName</span>
    </div>

    <!-- Hero Card -->
    <div class="sd-hero">
        <div class="sd-avatar">@initials</div>

        <div class="sd-hero-info">
            <h2 class="sd-hero-name">@Model.StuFullName</h2>
            <p class="sd-hero-meta">LRN: @Model.StuLRN · @Model.GradeSec</p>
            <div class="sd-hero-contacts">
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div class="sd-hero-contact-item">✉️ @Model.Email</div>
                }
                @if (!string.IsNullOrEmpty(Model.Contact))
                {
                    <div class="sd-hero-contact-item">📞 @Model.Contact</div>
                }
                @if (!string.IsNullOrEmpty(Model.Adviser))
                {
                    <div class="sd-hero-contact-item">👤 @Model.Adviser</div>
                }
            </div>
        </div>

        <div class="sd-hero-badges">
            @if (Model.StuStatus)
            {
                <span class="sd-badge sd-badge-active">● Active</span>
            }
            else
            {
                <span class="sd-badge sd-badge-inactive">● Inactive</span>
            }
            @if (!string.IsNullOrEmpty(Model.CaseType))
            {
                <span class="sd-badge sd-badge-case">@Model.CaseType</span>
            }
        </div>

        <div class="sd-hero-actions">
            <a asp-action="Edit" asp-route-id="@Model.StuID" class="sd-btn sd-btn-edit">
                ✏️ Edit
            </a>
        </div>
    </div>

    <!-- Tabs (visual only) -->
    <div class="sd-tabs">
        <span class="sd-tab active">Student Details</span>
        <span class="sd-tab">Visit History</span>
        <span class="sd-tab">Counseling Plan</span>
    </div>

    <!-- Info Cards -->
    <div class="sd-cards-grid">

        <!-- Basic Information -->
        <div class="sd-info-card">
            <div class="sd-info-card-header sch-indigo">📋 Basic Information</div>
            <div class="sd-field">
                <p class="sd-field-label">Gender</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Gender) ? "—" : Model.Gender)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Date of Birth</p>
                <p class="sd-field-value">@Model.Birthdate.ToString("yyyy-MM-dd")</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Contact</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Contact) ? "—" : Model.Contact)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Email</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Address</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)</p>
            </div>
        </div>

        <!-- Academic Info -->
        <div class="sd-info-card">
            <div class="sd-info-card-header sch-amber">🎓 Academic Info</div>
            <div class="sd-field">
                <p class="sd-field-label">Grade &amp; Section</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.GradeSec) ? "—" : Model.GradeSec)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">LRN</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.StuLRN) ? "—" : Model.StuLRN)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Adviser</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Adviser) ? "—" : Model.Adviser)</p>
            </div>
        </div>

        <!-- Guardian Info -->
        <div class="sd-info-card">
            <div class="sd-info-card-header sch-cyan">👨‍👩‍👧 Guardian Info</div>
            <div class="sd-field">
                <p class="sd-field-label">Guardian</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.GuardianName) ? "—" : Model.GuardianName)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Relationship</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Relationship) ? "—" : Model.Relationship)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Contact</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.GuardianContact) ? "—" : Model.GuardianContact)</p>
            </div>
            <div class="sd-field">
                <p class="sd-field-label">Address</p>
                <p class="sd-field-value">@(string.IsNullOrEmpty(Model.GuardianAddress) ? "—" : Model.GuardianAddress)</p>
            </div>
        </div>

        <!-- Guidance Info (full width) -->
        <div class="sd-info-card full">
            <div class="sd-info-card-header sch-rose">🧠 Guidance Info</div>
            <div class="sd-guidance-grid">
                <div class="sd-field">
                    <p class="sd-field-label">Case Type</p>
                    <p class="sd-field-value">@(string.IsNullOrEmpty(Model.CaseType) ? "—" : Model.CaseType)</p>
                </div>
                <div class="sd-field">
                    <p class="sd-field-label">Counseling Status</p>
                    <p class="sd-field-value">@(string.IsNullOrEmpty(Model.CounselingStatus) ? "—" : Model.CounselingStatus)</p>
                </div>
                <div class="sd-field">
                    <p class="sd-field-label">Reason</p>
                    <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Reason) ? "—" : Model.Reason)</p>
                </div>
                <div class="sd-field">
                    <p class="sd-field-label">Remarks</p>
                    <p class="sd-field-value">@(string.IsNullOrEmpty(Model.Remarks) ? "—" : Model.Remarks)</p>
                </div>
            </div>
        </div>

    </div>
</div>
