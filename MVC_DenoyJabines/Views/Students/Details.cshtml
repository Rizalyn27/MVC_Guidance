@model MVC_DenoyJabines.Models.Students

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">ℹ️ Student Details</h4>
        </div>

        <div class="card-body">

            <!-- 📋 BASIC INFO -->
            <h5 class="text-primary">📋 Basic Information</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Student ID</dt>
                <dd class="col-sm-9">@Model.StuLRN</dd>

                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">@Model.StuFullName</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @(Model.StuStatus ? "Active" : "Inactive")
                </dd>

                <dt class="col-sm-3">Gender</dt>
                <dd class="col-sm-9">@Model.Gender</dd>

                <dt class="col-sm-3">Birthdate</dt>
                <dd class="col-sm-9">@Model.Birthdate.ToString("yyyy-MM-dd")</dd>
            </dl>

            <!-- 📬 CONTACT -->
            <h5 class="text-success mt-4">📬 Contact</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.Address</dd>

                <dt class="col-sm-3">Contact</dt>
                <dd class="col-sm-9">@Model.Contact</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
            </dl>

            <!-- 🎓 ACADEMIC -->
            <h5 class="text-warning mt-4">🎓 Academic Info</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Department</dt>
                <dd class="col-sm-9">@Model.Department</dd>

                <dt class="col-sm-3">Grade & Section</dt>
                <dd class="col-sm-9">@Model.GradeSec</dd>

                <dt class="col-sm-3">Adviser</dt>
                <dd class="col-sm-9">@Model.Adviser</dd>
            </dl>

            <!-- 👨‍👩‍👧 GUARDIAN -->
            <h5 class="text-info mt-4">👨‍👩‍👧 Guardian Info</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Guardian Name</dt>
                <dd class="col-sm-9">@Model.GuardianName</dd>

                <dt class="col-sm-3">Relationship</dt>
                <dd class="col-sm-9">@Model.Relationship</dd>

                <dt class="col-sm-3">Contact</dt>
                <dd class="col-sm-9">@Model.GuardianContact</dd>

                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.GuardianAddress</dd>
            </dl>

            <!-- 🧠 GUIDANCE -->
            <h5 class="text-danger mt-4">🧠 Guidance Info</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Case Type</dt>
                <dd class="col-sm-9">@Model.CaseType</dd>

                <dt class="col-sm-3">Counseling Status</dt>
                <dd class="col-sm-9">@Model.CounselingStatus</dd>

                <dt class="col-sm-3">Reason</dt>
                <dd class="col-sm-9">@Model.Reason</dd>

                <dt class="col-sm-3">Remarks</dt>
                <dd class="col-sm-9">@Model.Remarks</dd>
            </dl>

            <!-- BUTTONS -->
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Edit" asp-route-id="@Model.StuID" class="btn btn-warning">✏️ Edit</a>
                <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
            </div>

        </div>
    </div>
</div>