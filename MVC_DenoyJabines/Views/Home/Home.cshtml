@{
    ViewData["Title"] = "Dashboard";
}

<style>

    :root {
        --navy: #0f2044;
        --teal: #1a7f74;
        --teal-light: #22a898;
        --teal-bg: #e6f7f5;
        --gold: #d9941a;
        --gold-bg: #fef6e8;
        --purple: #6b46c1;
        --purple-bg: #f3f0ff;
        --blue: #2b6cb0;
        --blue-bg: #bee3f8;
        --cream: #f3f5fb;
        --surface: #ffffff;
        --surface2: #f7f8fc;
        --border: #e2e8f4;
        --ink: #0e1523;
        --mid: #4a5568;
        --muted: #8896a6;
        --success: #276749;
        --success-bg: #c6f6d5;
        --warning: #b7791f;
        --warning-bg: #fefcbf;
        --shadow: 0 2px 16px rgba(15,32,68,.07);
        --shadow-md: 0 6px 28px rgba(15,32,68,.11);
        --radius: 18px;
        --radius-sm: 10px;
    }

    .counsel-page {
        font-family: 'Sora', sans-serif;
        background: var(--cream);
        min-height: 100vh;
        padding: 36px 32px;
        color: var(--ink);
    }

    /* ── Header ── */
    .dash-header {
        margin-bottom: 30px;
    }

        .dash-header h1 {
            font-family: Arial, Helvetica, sans-serif,;
            font-size: 2rem;
            font-weight: 400;
            color: var(--navy);
            margin-bottom: 4px;
            letter-spacing: -0.01em;
        }

        .dash-header p {
            color: var(--muted);
            font-size: 0.85rem;
        }

    /* ── Stat Grid ── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 22px 20px 20px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
        transition: box-shadow .2s, transform .2s;
    }

        .stat-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

        .stat-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: 0 0 var(--radius) var(--radius);
        }

    .sc-teal::after {
        background: var(--teal);
    }

    .sc-navy::after {
        background: var(--navy);
    }

    .sc-gold::after {
        background: var(--gold);
    }

    .sc-purple::after {
        background: var(--purple);
    }

    .stat-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .stat-label {
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--muted);
        letter-spacing: .07em;
        text-transform: uppercase;
        line-height: 1.5;
    }

    .stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
    }

    .icon-teal {
        background: var(--teal-bg);
    }

    .icon-navy {
        background: #e8edf5;
    }

    .icon-gold {
        background: var(--gold-bg);
    }

    .icon-purple {
        background: var(--purple-bg);
    }

    .stat-value {
        font-family: Arial, Helvetica, sans-serif,;
        font-size: 3rem;
        font-weight: 400;
        line-height: 1;
        margin-bottom: 6px;
    }

    .sc-teal .stat-value {
        color: var(--teal);
    }

    .sc-navy .stat-value {
        color: var(--navy);
    }

    .sc-gold .stat-value {
        color: var(--gold);
    }

    .sc-purple .stat-value {
        color: var(--purple);
    }

    .stat-sub {
        font-size: 0.78rem;
        color: var(--muted);
    }

    /* ── Bottom Grid ── */
    .bottom-grid {
        display: grid;
        grid-template-columns: 1.75fr 1fr;
        gap: 20px;
    }

    /* ── Card ── */
    .dash-card {
        background: var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 24px;
        box-shadow: var(--shadow);
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .card-title {
        font-family: Arial, Helvetica, sans-serif,;
        font-size: 1.2rem;
        font-weight: 400;
        color: var(--navy);
        margin: 0;
    }

    .badge-today {
        padding: 4px 14px;
        border-radius: 20px;
        background: var(--blue-bg);
        color: var(--blue);
        font-size: 0.72rem;
        font-weight: 700;
    }

    /* ── Visit Table ── */
    .visit-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.84rem;
    }

        .visit-table th {
            padding: 10px 14px;
            text-align: left;
            font-size: 0.65rem;
            font-weight: 700;
            color: var(--muted);
            letter-spacing: .07em;
            text-transform: uppercase;
            border-bottom: 1.5px solid var(--border);
        }

        .visit-table td {
            padding: 13px 14px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .visit-table tr:last-child td {
            border-bottom: none;
        }

        .visit-table tbody tr:hover td {
            background: var(--cream);
            transition: background .15s;
        }

    /* ── Avatar ── */
    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.82rem;
        color: #fff;
        flex-shrink: 0;
    }

    .student-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .student-name {
        font-weight: 600;
        color: var(--ink);
        line-height: 1.3;
        margin-bottom: 2px;
        font-size: 0.84rem;
    }

    .student-id {
        font-size: 0.72rem;
        color: var(--muted);
    }

    /* ── Badges ── */
    .badge-status {
        display: inline-flex;
        align-items: center;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 600;
    }

    .badge-upcoming {
        background: var(--blue-bg);
        color: var(--blue);
    }

    .badge-ongoing {
        background: var(--warning-bg);
        color: var(--warning);
    }

    .badge-done {
        background: var(--success-bg);
        color: var(--success);
    }

    .badge-academic {
        background: var(--blue-bg);
        color: var(--blue);
    }

    .badge-behavior {
        background: var(--warning-bg);
        color: var(--warning);
    }

    .badge-personal {
        background: var(--success-bg);
        color: var(--success);
    }

    /* ── Case Summary ── */
    .case-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 0;
        border-bottom: 1px solid var(--border);
    }

        .case-row:last-of-type {
            border-bottom: none;
        }

    .case-label {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.9rem;
        color: var(--ink);
    }

    .case-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .dot-teal {
        background: var(--teal);
    }

    .dot-gold {
        background: var(--gold);
    }

    .dot-navy {
        background: var(--navy);
    }

    /* ── Completion Rate ── */
    .completion-box {
        margin-top: 18px;
        background: var(--teal-bg);
        border-radius: 12px;
        padding: 14px 16px;
    }

    .completion-label {
        font-size: 0.72rem;
        color: var(--muted);
        margin-bottom: 5px;
    }

    .completion-value {
        font-family: Arial, Helvetica, sans-serif,;
        font-size: 2rem;
        color: var(--teal);
        margin-bottom: 9px;
    }

    .progress-track {
        height: 6px;
        background: var(--border);
        border-radius: 4px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: var(--teal);
        border-radius: 4px;
    }

    /* ── Responsive ── */
    @@media (max-width: 1100px) {
        .stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .bottom-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 600px) {
        .counsel-page {
            padding: 20px 16px;
        }

        .stat-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 400px) {
        .stat-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="counsel-page">

    <!-- ── Page Header ── -->
    <div class="dash-header">
        <h1>Dashboard</h1>
        <p>Welcome back! Here's what's happening today.</p>
    </div>

    <!-- ── Stat Cards ── -->
    <div class="stat-grid">

        <div class="stat-card sc-teal">
            <div class="stat-card-top">
                <div class="stat-label">Counseling<br />Cases</div>
                <div class="stat-icon icon-teal"></div>
            </div>
            <div class="stat-value">128</div>
            <div class="stat-sub">Total this year</div>
        </div>

        <div class="stat-card sc-navy">
            <div class="stat-card-top">
                <div class="stat-label">Enrolled<br />Students</div>
                <div class="stat-icon icon-navy"></div>
            </div>
            <div class="stat-value">3,247</div>
            <div class="stat-sub">Active students</div>
        </div>

        <div class="stat-card sc-gold">
            <div class="stat-card-top">
                <div class="stat-label">Visits<br />Today</div>
                <div class="stat-icon icon-gold"></div>
            </div>
            <div class="stat-value">14</div>
            <div class="stat-sub">8 individual, 6 group</div>
        </div>

        <div class="stat-card sc-purple">
            <div class="stat-card-top">
                <div class="stat-label">Cases This<br />Week</div>
                <div class="stat-icon icon-purple"></div>
            </div>
            <div class="stat-value">32</div>
            <div class="stat-sub">+7 from last week</div>
        </div>

    </div>

</div>
