@model MVC_DenoyJabines.Models.CaseNotes
@{
    ViewData["Title"] = "Delete Case Note";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=DM+Sans:wght@400;500&display=swap');

    :root {
        --rose: #f43f5e;
        --rose-dark: #e11d48;
        --rose-light: #fff1f2;
        --rose-border: #fecdd3;
        --slate: #1e293b;
        --surface: #f8fafc;
        --card: #ffffff;
        --border: #e2e8f0;
        --text: #0f172a;
        --muted: #64748b;
        --radius: 16px;
    }

    body {
        background: var(--surface);
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
    }

    .cn-page {
        padding: 32px 16px;
        max-width: 760px;
        margin: 0 auto;
    }

    .page-eyebrow {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: 'Outfit', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1.3px;
        text-transform: uppercase;
        color: var(--rose);
        margin-bottom: 6px;
    }

        .page-eyebrow::before {
            content: '';
            display: inline-block;
            width: 20px;
            height: 2px;
            background: var(--rose);
        }

    .page-title {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(1.5rem, 4vw, 2rem);
        font-weight: 800;
        color: var(--text);
        margin: 0 0 20px;
    }

    .danger-banner {
        background: var(--rose-light);
        border: 1.5px solid var(--rose-border);
        border-radius: 12px;
        padding: 14px 20px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 24px;
    }

        .danger-banner .d-icon {
            font-size: 1.3rem;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .danger-banner strong {
            font-family: 'Outfit', sans-serif;
            font-size: 0.92rem;
            font-weight: 700;
            color: #9f1239;
            display: block;
            margin-bottom: 2px;
        }

        .danger-banner p {
            font-size: 0.82rem;
            color: #be123c;
            margin: 0;
        }

    .detail-card {
        background: var(--card);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .preview-body {
        padding: 28px;
    }

    .preview-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .preview-field label {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 5px;
    }

    .preview-value {
        font-size: 0.92rem;
        color: var(--text);
        padding: 9px 14px;
        background: #f8fafc;
        border-radius: 8px;
        border: 1px solid var(--border);
        min-height: 38px;
    }

        .preview-value.accent-slate {
            border-left: 3px solid var(--slate);
        }

        .preview-value.accent-blue {
            border-left: 3px solid #3b82f6;
        }

        .preview-value.accent-green {
            border-left: 3px solid #10b981;
        }

    .form-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 28px;
        border-top: 1px solid var(--border);
        background: #fafafa;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 22px;
        border-radius: 10px;
        font-family: 'Outfit', sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
    }

    .btn-back {
        background: #f1f5f9;
        color: var(--muted);
        border: 1.5px solid var(--border);
    }

        .btn-back:hover {
            background: #e2e8f0;
            color: var(--text);
        }

    .btn-delete {
        background: var(--rose);
        color: #fff;
        box-shadow: 0 2px 8px rgba(244,63,94,.22);
    }

        .btn-delete:hover {
            background: var(--rose-dark);
        }

    @@media (max-width: 640px) {
        .cn-page {
            padding: 20px 12px;
        }

        .preview-row {
            grid-template-columns: 1fr;
        }

        .preview-body {
            padding: 18px;
        }

        .form-actions {
            padding: 16px 18px;
        }
    }
</style>

<div class="cn-page">
    <div class="page-eyebrow">Case Notes</div>
    <h1 class="page-title">🗑️ Delete Case Note</h1>

    <div class="danger-banner">
        <div class="d-icon">⚠️</div>
        <div>
            <strong>Are you sure you want to delete this case note?</strong>
            <p>This action cannot be undone. Please review the record below before confirming.</p>
        </div>
    </div>

    <div class="detail-card">
        <div class="preview-body">
            <div class="preview-row">
                <div class="preview-field">
                    <label>Student</label>
                    <div class="preview-value accent-slate">@Model.Student?.StuFullName</div>
                </div>
                <div class="preview-field">
                    <label>Counseling Approach</label>
                    <div class="preview-value accent-blue">@(string.IsNullOrEmpty(Model.CounselingApproach) ? "—" : Model.CounselingApproach)</div>
                </div>
                <div class="preview-field">
                    <label>Created</label>
                    <div class="preview-value accent-green">@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
                </div>
            </div>
        </div>
        <form asp-action="Delete">
            <input type="hidden" asp-for="CaseNoteId" />
            <div class="form-actions">
                <a asp-action="Index" class="btn btn-back">⬅ Back</a>
                <button type="submit" class="btn btn-delete">🗑️ Confirm Delete</button>
            </div>
        </form>
    </div>
</div>
